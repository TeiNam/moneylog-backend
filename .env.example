# 데이터베이스
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/moneylog

# JWT
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS (운영 환경에서만 사용)
AWS_REGION=ap-northeast-2
# AWS_SECRET_NAME=moneylog/production

# 이메일
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# 앱
APP_ENV=development
DEBUG=true

# CORS 허용 오리진 (운영 환경에서는 쉼표 구분 도메인 목록, 예: https://example.com,https://app.example.com)
ALLOWED_ORIGINS=*

# 구독 배치 API 인증 키
BATCH_API_KEY=your-batch-api-key-here

# Amazon Bedrock (AI 연동)
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_REGION=us-east-1
BEDROCK_TIMEOUT=30
