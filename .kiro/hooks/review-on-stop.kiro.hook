{
  "name": "Post-Task Code Review",
  "version": "1.0.0",
  "description": "작업 완료 시 보안, 에러 처리, 잔여 print문, 테스트 필요 여부를 자동 리뷰합니다.",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Briefly review the completed work: 1) any security issues 2) proper error handling 3) no leftover console.log 4) tests needed for changes. Report issues only."
  }
}
